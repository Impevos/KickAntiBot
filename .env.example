# DATABASE SETTINGS
# Connection string for Supabase PostgreSQL database
# Format: postgresql://[user]:[password]@[host]:[port]/[db_name]?schema=public
DATABASE_URL="postgresql://postgres:your-supabase-db-password@db.xxxxxx.supabase.co:5432/postgres"

# SUPABASE SETTINGS
# Your Supabase Project URL and Public Anon Key (for client interactions)
SUPABASE_URL="https://your-supabase-project-id.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# JWT SETTINGS
# secret used for local JWT verification if needed
JWT_SECRET="your-super-secret-jwt-signing-key"

# PORT CONFIGURATION
PORT=3000
