# DATABASE SETTINGS
# Transaction pooler connection (used by the app at runtime)
# Supabase Dashboard > Project Settings > Database > Connection string > Transaction pooler
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (required by Prisma for migrations and schema push)
# Supabase Dashboard > Project Settings > Database > Connection string > Session pooler (or Direct)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# SUPABASE SETTINGS
# Supabase Dashboard > Project Settings > API
SUPABASE_URL="https://your-supabase-project-id.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# JWT SETTINGS (reserved for future use; auth is handled via Supabase tokens)
JWT_SECRET="your-super-secret-jwt-signing-key"

# PORT CONFIGURATION
PORT=3000
